<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingTop="5dp"
    android:paddingBottom="3dp"
    android:paddingStart="2dp"
    android:paddingEnd="2dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/note_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#F2D6FF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/note_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:textColor="#99FFFFFF"
            android:textSize="10.5sp"
            android:maxLines="1"
            android:ellipsize="end" />

    </LinearLayout>

    <!-- "3/5" progress badge, or "Completed" once doneCount == totalCount.
         Sits at the trailing end of the header row, vertically centered
         against the title/time block beside it. -->
    <TextView
        android:id="@+id/note_count_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:textColor="#E3A2EE"
        android:textSize="11sp"
        android:textStyle="bold"
        android:maxLines="1" />

</LinearLayout>
